# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/garage_seo
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=garage_seo

# Redis (BullMQ + cache + rate limit)
REDIS_URL=redis://localhost:6379

# ─── Clerk auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ─── DataForSEO ───────────────────────────────────────────────────────────────
# Leave both blank to run keyword endpoints in mock-data mode.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── Google APIs ──────────────────────────────────────────────────────────────
GOOGLE_PAGESPEED_API_KEY=
# GSC + GA4 OAuth (server-side flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full URL of the GSC OAuth callback (must match Google Cloud Console)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gsc/callback
# AES-256-GCM key for encrypting OAuth tokens — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── AI providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=        # Required for AI-generated executive summaries in Reports
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Frontend / app URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Site Audit crawler (WSL2) ────────────────────────────────────────────────
# The Python crawler runs on Ubuntu/WSL2 and is not in this repo. The API
# calls POST {CRAWLER_URL}/crawl-site with {domain, max_pages, use_js}.
#
# If you run the crawler in WSL2, get its IP with:
#   hostname -I
# WSL2 NAT IPs change on each boot — re-export the new IP after rebooting WSL.
CRAWLER_URL=http://localhost:5001
CRAWLER_TYPE=scrapy
